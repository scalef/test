# ── Trading Safety ──────────────────────────────────────────────────────────
# Default mode is SIGNAL_ONLY — no orders are ever sent.
# Set to DEMO to enable simulated order execution.
# Set to LIVE only if you understand the risks and set ALLOW_LIVE_TRADING=true.
TRADING_MODE=SIGNAL_ONLY

# LIVE orders are blocked unless BOTH conditions are true:
#   TRADING_MODE=LIVE AND ALLOW_LIVE_TRADING=true
ALLOW_LIVE_TRADING=false

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL=sqlite:///./data/trading.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/trading

# ── Scheduler ────────────────────────────────────────────────────────────────
# How often to run the analysis cycle (in seconds)
SCHEDULER_INTERVAL_SECONDS=300

# ── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── MetaTrader 5 ─────────────────────────────────────────────────────────────
# MT5 connector is a placeholder. Real connection requires Windows + MetaTrader5 package.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_ENABLED=false

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: openai, anthropic
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o
